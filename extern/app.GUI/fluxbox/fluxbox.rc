session.configVersion: 13
session.screen0.menu.alpha:     160
session.screen0.slit.placement: TopCenter
session.screen0.slit.alpha:     255

! (toolbar) auto hide
session.screen0.slit.autoHide:  false
session.screen0.slit.onTop:     false
session.screen0.slit.maxOver:   false
session.screen0.slit.onhead:    0
session.screen0.slit.direction: Vertical
session.screen0.slit.layer:     Dock
session.screen0.tooltipDelay:   500

! (toolbar)
session.screen0.toolbar.widthPercent:   100
session.screen0.toolbar.tools:  iconbar, systemtray, clock
session.screen0.toolbar.height: 0
session.screen0.toolbar.onhead: 0
session.screen0.toolbar.layer:  AboveDock
session.screen0.toolbar.autoHide:       false
session.screen0.toolbar.placement:      BottomLeft
session.screen0.toolbar.visible:        true
session.screen0.toolbar.alpha:          255
session.screen0.toolbar.maxOver:        false
session.screen0.toolbar.onTop:  false
session.screen0.tab.placement:  Top
session.screen0.tab.alignment:  Left
session.screen0.tab.height:     16
session.screen0.tab.width:      64
session.screen0.tab.rotatevertical:     True

! (tabs) uses images to compose the layout
session.screen0.tabs.usePixmap:         false

! (title bar) does not divide in two bar, one with app title with width auto and other 100% with full description
session.screen0.tabs.intitlebar:        true

session.screen0.window.focus.alpha:     255
session.screen0.window.unfocus.alpha:   100
session.screen0.window.alpha:   180session.screen0.iconbar.deiconifyMode:  Follow
session.screen0.noFocusWhileTypingDelay:  0

! (toolbar) (icon) (visible)
session.screen0.iconbar.usePixmap:      true
session.screen0.iconbar.alignment:      Relative
session.screen0.iconbar.wheelMode:      Screen
session.screen0.iconbar.iconTextPadding:  10l
session.screen0.iconbar.iconWidth:      70
session.screen0.overlay.lineWidth:      1
session.screen0.overlay.lineStyle:      LineSolid
session.screen0.overlay.joinStyle:      JoinMiter
session.screen0.overlay.capStyle:       CapNotLast
session.screen0.iconbar.mode:   Workspace
session.screen0.showwindowposition:     true
session.screen0.antialias:      true
session.screen0.opaqueMove:     true
session.screen0.followModel:    Ignore
session.screen0.imageDither:    true
! setting controls how close a window needs to be to the edge of the screen before it snaps 
session.screen0.edgeSnapThreshold:      20
session.screen0.menuDelayClose: 0
session.screen0.windowMenu:
session.screen0.rowPlacementDirection:  LeftToRight
session.screen0.workspaces:     1
session.screen0.workspaceNames: Main
session.screen0.workspacewarping:       true

! time for menu appears
session.screen0.menuDelay:      0
session.screen0.autoRaise:                true
session.screen0.clickRaises:              true
session.screen0.clientMenu.usePixmap:     true
session.screen0.menuMode:       Delay
session.screen0.sloppywindowgrouping:   true
session.screen0.colPlacementDirection:  TopToBsession.screen0.decorateTransient:      false
session.screen0.strftimeFormat: %a %e/%b/%Y %l:%M

! (window) fullsize even if it goes behind the toolbar
session.screen0.focusNewWindows:          true
session.screen0.desktopwheeling:          true

session.screen0.maxDisableMove:           false
session.screen0.maxDisableResize:         false
! session.screen0.maxDisableMove:           true
! session.screen0.maxDisableResize:         true
session.screen0.maxIgnoreIncrement:       true
session.screen0.rootCommand:
session.screen0.tabs.maxOver:             false
session.screen0.tabFocusModel:            ClickToTabFocus
session.screen0.titlebar.left:            Stick
session.screen0.colPlacementDirection:    TopToBottom
session.screen0.defaultDeco:              NORMAL
session.screen0.edgeSnapThreshold:        10
! session.screen0.focusModel:               ClickFocus
session.screen0.focusModel:     SloppyFocus

! (title bar) (buttons) options
session.screen0.titlebar.right:           minimize maximize close

! (title bar) (buttons) options
session.numLayers:      13
session.opaqueMove:     True
session.focusTabMinWidth:       0
session.iconbar:        true
session.imageDither:    True

! double click speed
session.doubleClickInterval:    250
session.forcePseudoTransparency:        false
session.useMod1:        true
session.cacheMax:       200l
session.tabsAttachArea: Window
session.autoRaiseDelay: 250
session.tabs:   true
! session.menuFile:     <%= session.staged_root.join("fluxbox", "menu") %>
! session.keyFile:      <%= session.staged_root.join("fluxbox", "keys") %>
! session.styleOverlay: <%= session.staged_root.join("fluxbox", "overlay") %>


session.menuFile:     ${QNVSM}/fluxbox/menu
session.keyFile:      ${QNVSM}/fluxbox/keys
session.styleOverlay: ${QNVSM}/fluxbox/overlay

session.groupFile:      ~/.fluxbox/groups
session.appsFile:       ${QNVSM}/fluxbox/apps
session.slitlistFile:   ~/.fluxbox/slitlist

! (fluxbox) skin path
! session.styleFile:      ~/.fluxbox/styles/fluxy

! session.screen0.decorateTransient:      false
session.screen0.decorateTransient: true

session.screen0.strftimeFormat: %a %e/%b/%Y %l:%M
! windows to be resizable and movable without automatically maximizing
session.screen0.fullMaximization:       False
session.screen0.focusLastWindow:        true
session.screen0.windowPlacement:        RowSmartPlacement

session.screen0.autoRaise: false
! session.screen0.autoRaise:              true
session.screen0.rootCommand:
session.titlebar.left:  Stick
session.titlebar.right: Minimize Maximize Close
session.numLayers:      13
session.opaqueMove:     True
session.focusTabMinWidth:       0
session.iconbar:        true
session.imageDither:    True
session.forcePseudoTransparency:        false
session.useMod1:        true
session.cacheMax:       200l
session.tabsAttachArea: Window
session.autoRaiseDelay: 250
session.tabs:   true
session.tabPadding:     0
session.colorsPerChannel:       4
session.updateDelayTime:        0
session.cacheLife:      5l
session.ignoreBorder:   false

session.screen0.allowRemoteActions:	           true
#### Slit options
session.screen0.slit.acceptKdeDockapps:            true
session.screen0.focusSameHead: false
session.menuSearch:    itemstart
session.ignoreBorder:    false
