# click on the desktop to get menus
OnDesktop Mouse1 :HideMenus
OnDesktop Mouse2 :WorkspaceMenu
OnDesktop Mouse3 :RootMenu

# left click on the titlebar to move the window
OnTitlebar Mouse1 :MacroCmd {Raise} {Focus} {ActivateTab}
OnTitlebar Move1  :StartMoving

# control-click a window's titlebar and drag to attach windows
OnTitlebar Control Mouse1 :StartTabbing

# middle click on the titlebar to lower
OnTitlebar Mouse2 :Lower

# Normal window movement.
OnWindowBorder Move1 :StartMoving

# right click on the titlebar for a menu of options
OnTitlebar Mouse3 :WindowMenu

# double click on the titlebar to maximize
OnTitlebar Double Mouse1 :Maximize

# resize from bottom left or right corners
OnLeftGrip Move1 :StartResizing bottomleft
OnRightGrip Move1 :StartResizing bottomright

# alt + left/right click to move/resize a window
OnWindow Mod1 Mouse1 :MacroCmd {Raise} {Focus} {StartMoving}
OnWindow Mod1 Mouse3 :MacroCmd {Raise} {Focus} {StartResizing NearestCorner}

# Keyboard shortcuts for moving windows (MoveToEdge not supported in Fluxbox 1.3.7)
#Mod1 Left :MoveToEdge Left
#Mod1 Right :MoveToEdge Right
#Mod1 Up :MoveToEdge Up
#Mod1 Down :MoveToEdge Down
#Mod1 Shift Left :MoveToEdge TopLeft
#Mod1 Shift Right :MoveToEdge TopRight
#Mod1 Shift Up :MoveToEdge BottomLeft
#Mod1 Shift Down :MoveToEdge BottomRight

# Keyboard shortcuts for resizing windows
Mod1 Control Left :ResizeHorizontal -10
Mod1 Control Right :ResizeHorizontal +10
Mod1 Control Up :ResizeVertical -10
Mod1 Control Down :ResizeVertical +10

# Keyboard shortcuts for maximizing/restoring windows
Mod1 F11 :Maximize
#Mod1 F12 :Restore

# Keyboard shortcuts for moving windows between workspaces
Mod1 Shift Left :SendToWorkspace Left
Mod1 Shift Right :SendToWorkspace Right

# Keyboard shortcuts for raising/lowering windows
Mod1 R :Raise
Mod1 L :Lower

# Keyboard shortcut for closing windows
Mod1 Q :Close
