#!/bin/bash
set -e
nohup cpu.app --start-session > "$HOME/cpuapp.out" 2>&1 &
tries=0
while [[ $tries -lt 20 && ! -f "$HOME/.vnc/cpuapp.env" ]]; do
  sleep 1
  tries=$((tries + 1))
done
if [[ ! -f "$HOME/.vnc/cpuapp.env" ]]; then
  echo "cpuapp.env was not created yet. Check: tail -f $HOME/cpuapp.out" 1>&2
  exit 1
fi
echo "CPU GUI session ready."
echo "Connection info: $HOME/connection.yml"
echo 'Next in your current shell: eval "$(cpu.app --print-env)"'
