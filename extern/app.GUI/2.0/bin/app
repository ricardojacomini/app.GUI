#!/bin/bash
# -*- coding: utf-8 -*-
# The Advanced Research Computing at Hopkins (ARCH)
# Ricardo S Jacomini < rdesouz4 @ jhu.edu >
# Date: March, 23 2025


set -e

backend="cpu"
mode=""
geometry=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --gpu)
      backend="gpu"
      shift
      ;;
    --cpu)
      backend="cpu"
      shift
      ;;
    --geometry)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --geometry" 1>&2
        exit 1
      fi
      geometry="$2"
      shift 2
      ;;
    --start-session)
      mode="start-session"
      shift
      break
      ;;
    --print-env)
      mode="print-env"
      shift
      break
      ;;
    --run)
      mode="run"
      shift
      break
      ;;
    --stop)
      mode="stop"
      shift
      break
      ;;
    --cleanup)
      mode="cleanup"
      shift
      break
      ;;
    --help|-h)
      mode="help"
      shift
      break
      ;;
    *)
      echo "Unknown option: $1" 1>&2
      mode="help"
      break
      ;;
  esac
done

case "$mode" in
  start-session)
    mkdir -p "$HOME/.app.GUI/${backend}"
    exec "${backend}.app" ${geometry:+--geometry "$geometry"} --start-session
    ;;
  print-env)
    mkdir -p "$HOME/.app.GUI/${backend}"
    exec "${backend}.app" --print-env
    ;;
  run)
    if [[ $# -eq 0 ]]; then
      echo "Usage: app [--gpu] --run <application> [args...]" 1>&2
      exit 1
    fi
    mkdir -p "$HOME/.app.GUI/${backend}"
    # Source environment from active session if available
    env_output=$(${backend}.app --print-env 2>&1)
    if [[ "$env_output" == *"not found"* ]] || [[ -z "$env_output" ]]; then
      echo "Error: No active ${backend} session found." 1>&2
      if [[ "$backend" == "gpu" ]]; then
        echo "Start a session first with: app --gpu --start-session" 1>&2
      else
        echo "Start a session first with: app --start-session" 1>&2
      fi
      exit 1
    fi
    eval "$env_output" || true
    exec "${backend}-run" "$@"
    ;;
  stop)
    # Silenced: Stopping active VNC session
    found_session=0
    # Find active sessions by looking for display directories with running Xvnc
    for backend_dir in "$HOME/.app.GUI"/*/; do
      if [[ ! -d "$backend_dir" ]]; then continue; fi

      # Try to find running sessions by checking xvnc.pid files
      for session_dir in "${backend_dir}"/display-*; do
        if [[ ! -d "$session_dir" ]]; then continue; fi

        xvnc_pid=""
        if [[ -f "$session_dir/xvnc.pid" ]]; then
          xvnc_pid=$(cat "$session_dir/xvnc.pid" 2>/dev/null)
        fi

        # Check if Xvnc is actually running for this session
        if [[ -n "$xvnc_pid" ]] && kill -0 "$xvnc_pid" 2>/dev/null; then
          found_session=1
          # Silenced: Stopping: $session_dir"

          # Extract display number from session dir (e.g., display-3 -> 3)
          display_num=$(basename "$session_dir" | sed 's/display-//')

          # Kill processes in order
          for pidfile in keepalive.pid fluxbox.pid vnc_monitor.pid xvnc.pid; do
            if [[ -f "$session_dir/$pidfile" ]]; then
              pid=$(cat "$session_dir/$pidfile" 2>/dev/null)
              if [[ -n "$pid" ]]; then
                kill -TERM "$pid" 2>/dev/null || true
              fi
            fi
          done

          sleep 1

          # Force kill remaining processes
          for pidfile in keepalive.pid fluxbox.pid xvnc.pid; do
            if [[ -f "$session_dir/$pidfile" ]]; then
              pid=$(cat "$session_dir/$pidfile" 2>/dev/null)
              if [[ -n "$pid" ]]; then
                kill -KILL "$pid" 2>/dev/null || true
              fi
            fi
          done

          # Clean up X11 sockets and lock files for this display
          rm -f "/tmp/.X${display_num}-lock" "/tmp/.X11-unix/X${display_num}" 2>/dev/null || true

          # Remove session directory
          rm -rf "$session_dir" 2>/dev/null || true
          rm -f "${backend_dir}current" 2>/dev/null || true

          echo "✓ Session stopped"
        fi
      done
    done

    if [[ $found_session -eq 0 ]]; then
      echo "No active sessions found"
    fi
    ;;
  cleanup)
    echo "Cleaning up all VNC sessions..."
    # Kill the app wrapper scripts first
    pkill -9 -f "cpu\.app" 2>/dev/null || true
    pkill -9 -f "gpu\.app" 2>/dev/null || true

    sleep 1

    # Force kill all remaining processes
    pkill -9 -f "Xvnc.*${USER}" 2>/dev/null || true
    pkill -9 -f "fluxbox.*${USER}" 2>/dev/null || true
    pkill -9 -f "singularity.*${USER}" 2>/dev/null || true
    pkill -9 -f "tail.*vnc.log" 2>/dev/null || true

    sleep 1

    # Remove PID files to release locks
    find "$HOME/.app.GUI" -name "*.pid" -delete 2>/dev/null || true

    # Remove all app.GUI directories (with retry for NFS locks)
    for i in {1..3}; do
      rm -rf "$HOME/.app.GUI" 2>/dev/null && break
      sleep 1
    done || true

    # Remove VNC files
    rm -f "$HOME/vnc.log" "$HOME/vnc.passwd" "$HOME/gpuapp.env" "$HOME/connection.yml" 2>/dev/null || true

    # Remove X11 sockets and lock files (only those owned by this user)
    find /tmp/.X*-lock -user "${USER}" -delete 2>/dev/null || true
    for sock in /tmp/.X11-unix/X*; do
      if [[ -S "$sock" ]]; then
        ls -l "$sock" 2>/dev/null | grep -q "${USER}" && rm -f "$sock" 2>/dev/null || true
      fi
    done

    echo "✓ Cleanup complete - all VNC sessions removed"
    ;;
  help|"")
    cat <<'END_HELP'
Usage:
  app [--geometry WIDTHxHEIGHT] --start-session
  app --run <application> [args...]
  app --print-env
  app --stop              (stop active session)
  app --cleanup           (remove all sessions)
  app --gpu [--geometry WIDTHxHEIGHT] --start-session
  app --gpu --run <application> [args...]
  app --gpu --print-env

Default backend:
  CPU

Supported resolutions:
  1024x768
  1280x1024
  1920x1080
  2560x1440

Resolution:
  Use --geometry WIDTHxHEIGHT, or run --start-session in the foreground to choose from a menu.

Examples:
  app --start-session &
  app --geometry 1024x768 --start-session &
  app --geometry 1920x1080 --start-session &
  ml matlab/R2021a
  app --run matlab -desktop &
  app --stop # stop active session
  app --cleanup # remove all sessions

  app --gpu --start-session &
  app --gpu --geometry 2560x1440 --start-session &
  ml matlab/R2021a
  app --gpu --run matlab -desktop

  app --start-session & # default geometry 1024x768
  ml matlab/R2021a
  app --run matlab -desktop

  app --run xterm -fa "DejaVu Sans Mono" -fs 11 -bg "#1e1e1e" -fg "#d4d4d4"


END_HELP
    ;;
esac
